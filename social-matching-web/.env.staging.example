# STAGING frontend runtime (this file is the shape for `.env.staging.local`).
# `npm run dev` uses Vite `--mode staging`, which loads `.env.staging.local` automatically.
VITE_SUPABASE_URL=https://huzcvjyyyuudchnrosvx.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-staging-publishable-key
VITE_SUPABASE_PROJECT_ID=huzcvjyyyuudchnrosvx

# Optional — participant landing footer mailto ("צור קשר")
# VITE_SUPPORT_EMAIL=support@example.com

# STAGING programmatic validation users
STAGING_PROJECT_REF=huzcvjyyyuudchnrosvx
STAGING_SUPABASE_URL=https://huzcvjyyyuudchnrosvx.supabase.co
# Public anon key (same as browser / VITE publishable key) — used when documenting queue→send-event-email invoke patterns
STAGING_SUPABASE_ANON_KEY=your-staging-anon-key
STAGING_SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
# Optional: same value as Edge secret PROCESS_EMAIL_QUEUE_SERVICE_KEY — use for apikey + Authorization when calling process-email-queue
STAGING_PROCESS_EMAIL_QUEUE_SERVICE_KEY=your-staging-queue-invoke-secret
STAGING_VALIDATION_SHARED_PASSWORD=replace-with-one-shared-staging-password
STAGING_ADMIN1_EMAIL=admin1@example.com
STAGING_HOST1_EMAIL=host1@example.com
STAGING_P1_EMAIL=p1@example.com
STAGING_P2_EMAIL=p2@example.com
STAGING_P3_EMAIL=p3@example.com
STAGING_P4_EMAIL=p4@example.com
STAGING_P5_EMAIL=p5@example.com
STAGING_VALIDATION_USERS_OUTPUT=output/staging-validation-users.json

# STAGING edge/ops runtime (local reference only — Edge secrets are set in Supabase Dashboard / CLI per scripts/supabase/README.md)
SUPABASE_SERVICE_ROLE_KEY=your-staging-service-role-key
SUPABASE_DB_URL=postgresql://postgres:password@db.huzcvjyyyuudchnrosvx.supabase.co:5432/postgres

# STAGING email runtime (Edge secrets for send-event-email — curated validation used Gmail SMTP)
EMAIL_FROM_ADDRESS=no-reply@your-verified-domain.com
GMAIL_USER=your-gmail-address@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password
# Optional alternative if you switch send-event-email to Resend:
# EMAIL_PROVIDER=resend
# RESEND_API_KEY=your-staging-resend-api-key

# STAGING Stripe + Checkout (Edge secrets — mirror names in Dashboard; not used by Vite directly)
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# PAYMENT_CHECKOUT_SUCCESS_URL=https://your-staging-app.example/payment/success?session_id={CHECKOUT_SESSION_ID}
# PAYMENT_CHECKOUT_CANCEL_URL=https://your-staging-app.example/payment/cancel
