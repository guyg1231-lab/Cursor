# Copy to .env.ops.local (gitignored) and fill in. Used by: npm run ops:sync-vercel-vite-env
#
# Optional if already logged in locally:
#   VERCEL_TOKEN — otherwise read from Vercel CLI auth.json (macOS: Library/Application Support/com.vercel.cli)
#   SUPABASE_ACCESS_TOKEN — otherwise `supabase projects api-keys -o json` on PATH, else ~/.supabase/access-token
#   SUPABASE_SKIP_CLI=1 — force-disable Supabase CLI key resolution (CI / locked-down runners)
#
# Optional — if you ran `vercel link`, projectId + team come from .vercel/project.json automatically:
# VERCEL_PROJECT_ID=prj_…
# VERCEL_TEAM_ID=team_…
#
# Optional — production Supabase ref (Vercel Production target):
# SUPABASE_PROJECT_REF=nshgmuqlivuhlimwdwhe
#
# Optional — staging Supabase ref (Vercel Preview + Development targets):
# STAGING_PROJECT_REF=huzcvjyyyuudchnrosvx
#
# Legacy: one ref for all Vercel targets (not recommended):
# VERCEL_SUPABASE_ENV_UNIFIED=1
